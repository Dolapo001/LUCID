# Copy to backend/.env and adjust. All values are optional.
# Without a DB_* config the project uses a zero-config SQLite database.

# DJANGO_SECRET_KEY=change-me-in-production
# DJANGO_DEBUG=true
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL (uncomment to use Postgres instead of SQLite) ---
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=precision_dairy
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432

# --- API behaviour ---
# DRF_REQUIRE_AUTH=false
# DRF_PAGE_SIZE=50
